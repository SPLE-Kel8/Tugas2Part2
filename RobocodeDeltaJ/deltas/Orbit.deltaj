delta Orbit {
  modifies jab.module.Movement {

    adds int orbitDirection = 1;

    modifies move() {
      // Gerak menyamping untuk “ngorbit” musuh.
      // turnRight(90) + ahead() = strafe.
      bot.setTurnRight(90 * orbitDirection);
      bot.setAhead(120);

      // Sesekali ganti arah supaya tidak mudah ditembak
      orbitDirection *= -1;
    }
  }
}